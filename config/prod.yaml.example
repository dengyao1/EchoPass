# EchoPass · 生产环境配置模板
# ----------------------------------------------------------------------------
# 推荐：./scripts/first-run.sh（macOS/Linux）会复制本文件为 config/prod.yaml（若不存在）；
# 再编辑 prod.yaml 填好 ☆ 项，然后 ./scripts/run.sh
# 若仓库根已有 config/prod.yaml，可不再设置 ECHOPASS_CONFIG。
# 任意字段可临时被同名 SPEAKER_* 环境变量覆盖。
# ----------------------------------------------------------------------------

speaker:
  threshold: 0.45
  model_id: ""
  # 留空 = 仅内存（开源/单机默认，重启后已注册声纹不保留）。需要持久化再填 DSN
  pg_dsn: ""                   # 可选；填 PostgreSQL DSN 时启用声纹表持久化

assistant:
  ttl_sec: 25
  # 会中助手多轮对话：保留最近 N 轮（user+assistant 各算半轮）；0=关闭记忆
  chat_history_turns: 8
  # 可选：相对 echopass/static/；仓库内可生成 audio/wake_ack_01…wav ~ 03…wav
  wake_ack_audio: ""
  meeting_ctx:
    max_items: 20
    max_chars: 1500

# AI 章节：按话题切分 + 标题/摘要（见 echopass/meeting/summarizer.py）
meeting:
  chapters:
    # 喂给章节 LLM 的最大转写条数（40~200）；长会可适当增大，注意 token 与超时
    prompt_max_lines: 120
  # 跨会议总结（预留，见 echopass/meeting/cross_meeting.py 与 POST /api/meeting/summary/cross）
  cross_summary:
    # 单次请求最多纳入多少场（防止 prompt 过长）；环境变量 SPEAKER_CROSS_SUMMARY_MAX_MEETINGS 可覆盖
    max_meetings: 20

preload_models: true

llm:
  api_url: ""                  # ☆ 例如 https://api.deepseek.com/v1/chat/completions
  api_key: ""                  # ☆ 自有 LLM Key
  model: ""                    # ☆ 例如 deepseek-chat / qwen-plus / ep-xxx-xxx
  # 单次 chat / 流式整段请求超时（秒）；纪要、章节、助手共用 LLMChatClient
  timeout_sec: 120
  asr_correction: false

asr:
  hotword: ""
  funasr_base: ""
  # 进程内同时进行中的火山 ASR WebSocket 上限；多场会议并行时每场可各占 1 槽位。
  # 0 = 不限制（易把出口带宽/火山侧连接打满，不推荐生产）
  max_concurrent: 32
  volc:
    api: "bigmodel"
    appid: ""                  # ☆ 火山 ASR AppID
    token: ""                  # ☆ 火山 ASR Access Token
    cluster: "volcengine_streaming_common"
    ws_url: ""
    resource_id: ""
    model_name: ""
    language: ""
    workflow: ""
    uid: ""
    seg_ms: 0

kws:
  # 默认 false：不预加载/不下载本地 CTC 唤醒词模型。要用「小云小云」语音唤醒时改为 true
  # 环境变量：SPEAKER_KWS_ENABLED=1 与 yaml 中 enabled: true 等效
  enabled: false
  keywords: "小云小云"
  threshold: 0.75

tts:
  # 默认：火山豆包双向流式 TTS V3（凭据可与 asr.volc.appid / token 共用，见下方 volc）
  provider: "volc_bidirection"   # volc_bidirection | openai
  url: ""                        # openai 模式必填；火山模式留空即可
  api_key: "none"                # 仅 openai 模式使用
  voice: "zh_female_vv_uranus_bigtts"   # 兜底音色；/api/tts 请求体 voice 优先
  model: "tts-1"                 # 仅 openai 模式使用
  pcm:
    sample_rate: 24000
    channels: 1
    sample_width: 2
  volc:
    ws_url: ""
    appid: ""                    # 留空则沿用 asr.volc.appid
    access_key: ""               # 留空则沿用 asr.volc.token
    # resource_id 须与音色所属模型版本一致：2.0 → seed-tts-2.0；1.0 公版见控制台
    resource_id: "seed-tts-2.0"
    speaker: "zh_female_vv_uranus_bigtts"   # ☆ 豆包音色 ID（控制台复制）
    speech_rate: 0               # 语速 -50~100
    loudness_rate: 0             # 音量 -50~100
